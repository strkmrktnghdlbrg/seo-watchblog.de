---
interface Props {
  pros: string[];
  cons: string[];
}
const { pros, cons } = Astro.props;
---
<div class="procon">
  <div class="col">
    <h4>Das spricht dafür</h4>
    <ul class="pro">
      {pros.map((p) => <li>{p}</li>)}
    </ul>
  </div>
  <div class="col">
    <h4>Das spricht dagegen</h4>
    <ul class="con">
      {cons.map((c) => <li>{c}</li>)}
    </ul>
  </div>
</div>

<style>
  .procon { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .procon .col { background: var(--color-snow); border-radius: var(--radius-cards); padding: 24px; box-shadow: var(--shadow-subtle); }
  .procon h4 { font-family: var(--font-serif); font-size: 19px; margin-bottom: 14px; }
  .procon ul { list-style: none; display: flex; flex-direction: column; gap: 10px; font-size: 15px; color: #4a423d; }
  .procon .pro li::before { content: "＋ "; color: #2e9e6b; font-weight: 700; }
  .procon .con li::before { content: "－ "; color: #c0613f; font-weight: 700; }

  @media (max-width: 640px) {
    .procon { grid-template-columns: 1fr; }
  }
</style>
