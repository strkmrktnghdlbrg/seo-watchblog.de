---
interface Props {
  tool: any;
  rank?: number;
}
const { tool, rank } = Astro.props;

const full = Math.round(tool.scoreOverall);
const stars = '★'.repeat(full) + '☆'.repeat(Math.max(0, 5 - full));
const scoreFmt = tool.scoreOverall.toFixed(1);
---
<article class="tool-card">
  <div class={`tool-thumb ${tool.gradient}`}>
    {rank && <span class="rank">{rank}</span>}
    {tool.shortName}
  </div>
  <div class="tool-body">
    <h3>{tool.name}</h3>
    <div class="cat">{tool.category}</div>
    <div class="score">
      <span class="num">{scoreFmt}</span><span class="out">/ 5.0</span>
      <span class="stars">{stars}</span>
    </div>
    <p class="tool-desc">{tool.verdict}</p>
    <a class="btn btn-azure" href={`/tools/review/${tool.id}/`}>Zum Testbericht</a>
  </div>
</article>

<style>
  .tool-card {
    background: var(--color-snow); border-radius: var(--radius-cards); padding: 8px 8px 22px;
    box-shadow: var(--shadow-subtle); display: flex; flex-direction: column;
    transition: transform .15s, box-shadow .15s; height: 100%;
  }
  .tool-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); }
  .tool-thumb {
    border-radius: var(--radius-images); height: 116px; display: flex; align-items: center; justify-content: center;
    font-family: var(--font-serif); font-size: 30px; color: var(--color-inkwell); position: relative; overflow: hidden;
  }
  .tool-thumb .rank {
    position: absolute; top: 10px; left: 10px; background: var(--color-inkwell); color: var(--color-snow);
    font-family: var(--font-sans); font-size: 12px; font-weight: 600; width: 26px; height: 26px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
  }
  .tool-body { padding: 16px 12px 0; flex: 1; display: flex; flex-direction: column; }
  .tool-body h3 { font-size: 21px; letter-spacing: -0.4px; margin-bottom: 4px; }
  .tool-body .cat { font-size: 13px; color: var(--color-stone-gray); margin-bottom: 12px; }
  .score { display: flex; align-items: baseline; gap: 8px; margin-bottom: 12px; }
  .score .num { font-family: var(--font-serif); font-size: 30px; line-height: 1; }
  .score .out { font-size: 13px; color: var(--color-stone-gray); }
  .stars { color: var(--color-action-azure); font-size: 14px; letter-spacing: 2px; }
  .tool-desc { font-size: 14px; color: #4a423d; line-height: 1.5; margin-bottom: 16px; flex: 1; }
  .tool-card .btn-azure { width: 100%; text-align: center; }
</style>
