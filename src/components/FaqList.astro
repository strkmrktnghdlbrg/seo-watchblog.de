---
interface Faq {
  q: string;
  a: string;
}
interface Props {
  faqs: Faq[];
}
const { faqs } = Astro.props;
---
<div class="faq">
  {faqs.map((faq, i) => (
    <details open={i === 0}>
      <summary>{faq.q}</summary>
      <p>{faq.a}</p>
    </details>
  ))}
</div>

<style>
  .faq { display: flex; flex-direction: column; gap: 12px; max-width: 820px; }
  .faq details { background: var(--color-snow); border-radius: 18px; padding: 18px 22px; box-shadow: var(--shadow-subtle); }
  .faq summary { font-family: var(--font-serif); font-size: 18px; cursor: pointer; list-style: none; display: flex; justify-content: space-between; gap: 16px; }
  .faq summary::-webkit-details-marker { display: none; }
  .faq summary::after { content: "+"; color: var(--color-action-azure); font-size: 22px; }
  .faq details[open] summary::after { content: "–"; }
  .faq p { margin-top: 12px; font-size: 15px; color: #4a423d; line-height: 1.6; }
</style>
