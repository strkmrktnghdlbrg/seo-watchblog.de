---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Kontakt - SEO Watchblog"
  description="Fragen, Feedback oder ein Hinweis zu einem Test? Schreib der Redaktion von SEO Watchblog über das Kontaktformular."
>
  <div class="wrap">
    <div class="crumb"><a href="/">Home</a> › <span>Kontakt</span></div>
  </div>

  <section class="wrap page-head">
    <span class="eyebrow">Kontakt</span>
    <h1>Schreib uns</h1>
    <p class="intro">Du hast eine Frage zu einem Test, einen Hinweis auf einen Fehler oder einen Vorschlag für ein Tool, das wir uns ansehen sollen? Nutze das Formular, wir melden uns in der Regel innerhalb weniger Werktage.</p>
  </section>

  <section class="wrap">
    <div class="contact-card">
      <form action="https://api.web3forms.com/submit" method="POST">
        <input type="hidden" name="access_key" value="b65f4e95-6ac7-4003-a46a-fe4e08b120e2" />
        <input type="hidden" name="subject" value="Neue Nachricht über SEO Watchblog" />
        <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

        <div class="field">
          <label for="name">Name</label>
          <input type="text" id="name" name="name" required autocomplete="name" placeholder="Dein Name" />
        </div>

        <div class="field">
          <label for="email">E-Mail</label>
          <input type="email" id="email" name="email" required autocomplete="email" placeholder="name@beispiel.de" />
        </div>

        <div class="field">
          <label for="nachricht">Nachricht</label>
          <textarea id="nachricht" name="nachricht" rows="6" required placeholder="Worum geht es?"></textarea>
        </div>

        <button type="submit" class="btn btn-azure">Nachricht senden</button>
        <p class="form-note">Mit dem Absenden stimmst du der Verarbeitung deiner Angaben zur Bearbeitung der Anfrage zu. Details findest du in der <a href="/datenschutz/">Datenschutzerklärung</a>.</p>
      </form>
    </div>
  </section>

  <style>
    .crumb { font-size: 13px; color: var(--color-stone-gray); padding: 26px 0 0; }
    .crumb a:hover { color: var(--color-action-azure); }
    .page-head { padding: 18px 0 32px; }
    .page-head .eyebrow { display: inline-block; background: rgba(237,237,237,0.85); font-size: 13px; font-weight: 500; padding: 5px 13px; border-radius: 24px; margin-bottom: 16px; }
    .page-head h1 { font-size: clamp(34px, 5vw, 52px); line-height: 1.05; letter-spacing: -1.4px; max-width: 820px; margin-bottom: 16px; }
    .page-head p.intro { font-size: 18px; color: #4a423d; max-width: 680px; line-height: 1.55; }

    section { padding: 40px 0; }

    .contact-card { background: var(--color-snow); border-radius: var(--radius-cards); box-shadow: var(--shadow-subtle); padding: 32px; max-width: 640px; }
    .field { display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px; }
    .field label { font-size: 14px; font-weight: 600; color: var(--color-inkwell); }
    .field input, .field textarea {
      font-family: var(--font-sans); font-size: 16px; color: var(--color-inkwell);
      background: #faf9f8; border: 1px solid var(--color-distant-sky); border-radius: 16px;
      padding: 12px 14px; transition: border-color .15s, box-shadow .15s; width: 100%;
    }
    .field textarea { resize: vertical; }
    .field input:focus, .field textarea:focus {
      outline: none; border-color: var(--color-action-azure);
      box-shadow: 0 0 0 3px rgba(74,131,245,0.15);
    }
    .field input::placeholder, .field textarea::placeholder { color: var(--color-stone-gray); }

    .contact-card .btn-azure { padding: 12px 24px; font-size: 16px; }
    .form-note { font-size: 12px; color: var(--color-stone-gray); margin-top: 14px; line-height: 1.5; }
    .form-note a { color: var(--color-action-azure); }
  </style>
</BaseLayout>
