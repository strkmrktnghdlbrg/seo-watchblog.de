---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import SectionHead from '../../components/SectionHead.astro';
import ArticleCard from '../../components/ArticleCard.astro';

const clusters: { slug: string; title: string; desc: string }[] = [
  { slug: 'grundlagen', title: 'Grundlagen', desc: 'Wie Suchmaschinen funktionieren und worauf es beim Start ankommt.' },
  { slug: 'onpage', title: 'OnPage-SEO', desc: 'Inhalte, Meta-Tags, interne Links und Snippets richtig optimieren.' },
  { slug: 'offpage-linkbuilding', title: 'OffPage & Linkbuilding', desc: 'Backlinks, Domain-Autorität und nachhaltige Link-Strategien.' },
  { slug: 'technisches-seo', title: 'Technisches SEO', desc: 'Ladezeit, Core Web Vitals, Indexierung und strukturierte Daten.' },
  { slug: 'lokales-seo', title: 'Lokales SEO', desc: 'Sichtbarkeit in der Region: Google Business, Bewertungen und mehr.' },
  { slug: 'ecommerce-seo', title: 'E-Commerce-SEO', desc: 'Produktseiten, Kategorien und Shops für die Suche optimieren.' },
  { slug: 'content-keywords', title: 'Content & Keywords', desc: 'Keyword-Recherche, Content-Strategie und Wettbewerbsanalyse.' },
];

const all = await getCollection('articles', (e) => e.data.section === 'seo-wissen' && !e.data.draft);

const byCluster = clusters.map((c) => ({
  ...c,
  articles: all
    .filter((a) => a.data.cluster === c.slug)
    .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()),
})).filter((c) => c.articles.length > 0);
---
<BaseLayout
  title="SEO-Wissen: Grundlagen, OnPage, OffPage & Technik | SEO Watchblog"
  description="Verständlich erklärtes SEO-Wissen: von den Grundlagen über OnPage und OffPage bis zu technischem, lokalem und E-Commerce-SEO."
>
  <div class="wrap">
    <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'SEO-Wissen' }]} />
    <div class="page-head">
      <span class="eyebrow">{all.length} Ratgeber-Artikel · laufend aktualisiert</span>
      <h1>SEO-Wissen, verständlich erklärt</h1>
      <p class="intro">Von den Grundlagen bis zur Technik: Hier findest du fundiertes SEO-Wissen, geordnet nach Themenfeldern. Jeder Cluster bündelt die wichtigsten Beiträge zu einem Bereich.</p>
    </div>
  </div>

  {byCluster.map((c) => (
    <section class="wrap">
      <SectionHead
        title={c.title}
        subtitle={c.desc}
        linkHref={`/seo-wissen/${c.slug}/`}
        linkLabel="Alle Artikel"
      />
      <div class="articles">
        {c.articles.map((article) => <ArticleCard article={article} />)}
      </div>
    </section>
  ))}

  <style>
    .articles { display: grid; grid-template-columns: repeat(3, 1fr); gap: 26px; }
    @media (max-width: 1000px) { .articles { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 640px) { .articles { grid-template-columns: 1fr; } }
  </style>
</BaseLayout>
