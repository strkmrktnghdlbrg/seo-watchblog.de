---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import ArticleCard from '../../components/ArticleCard.astro';

const articles = (await getCollection('articles', (e) => e.data.section === 'watchblog' && !e.data.draft))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---
<BaseLayout
  title="Watchblog: Google-Updates, KI-Suche & SEO-News | SEO Watchblog"
  description="Aktuelle Google-Updates, KI-Suche und Branchen-News aus der SEO-Welt - immer auf dem neuesten Stand."
>
  <div class="wrap">
    <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Watchblog' }]} />
    <div class="page-head">
      <span class="eyebrow">{articles.length} Beiträge · laufend aktualisiert</span>
      <h1>Watchblog</h1>
      <p class="intro">Google-Updates, KI-Suche und Trends aus der SEO-Welt. Hier behalten wir die wichtigsten Entwicklungen für dich im Blick - neueste Beiträge zuerst.</p>
    </div>
  </div>

  <section class="wrap">
    {articles.length > 0 ? (
      <div class="articles">
        {articles.map((article) => <ArticleCard article={article} />)}
      </div>
    ) : (
      <p class="empty">Aktuell sind keine Beiträge veröffentlicht.</p>
    )}
  </section>

  <style>
    .articles { display: grid; grid-template-columns: repeat(3, 1fr); gap: 26px; }
    .empty { color: var(--color-stone-gray); font-size: 16px; }
    @media (max-width: 1000px) { .articles { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 640px) { .articles { grid-template-columns: 1fr; } }
  </style>
</BaseLayout>
