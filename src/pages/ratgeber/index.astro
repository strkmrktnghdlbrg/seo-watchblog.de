---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import ArticleCard from '../../components/ArticleCard.astro';

const articles = (await getCollection('articles', (e) => e.data.section === 'ratgeber' && !e.data.draft))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---
<BaseLayout
  title="SEO-Ratgeber: Anleitungen, Audits & Checklisten | SEO Watchblog"
  description="Schritt-für-Schritt-Anleitungen rund um SEO: Audit, Checklisten, Erfolgsmessung und mehr - praxisnah erklärt."
>
  <div class="wrap">
    <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Ratgeber' }]} />
    <div class="page-head">
      <span class="eyebrow">{articles.length} Anleitungen · praxisnah</span>
      <h1>SEO-Ratgeber</h1>
      <p class="intro">Schritt-für-Schritt durch die Praxis: Audits, Checklisten und Anleitungen, mit denen du SEO-Aufgaben strukturiert angehst und deinen Erfolg messbar machst.</p>
    </div>
  </div>

  <section class="wrap">
    {articles.length > 0 ? (
      <div class="articles">
        {articles.map((article) => <ArticleCard article={article} />)}
      </div>
    ) : (
      <p class="empty">Aktuell sind keine Anleitungen veröffentlicht.</p>
    )}
  </section>

  <style>
    .articles { display: grid; grid-template-columns: repeat(3, 1fr); gap: 26px; }
    .empty { color: var(--color-stone-gray); font-size: 16px; }
    @media (max-width: 1000px) { .articles { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 640px) { .articles { grid-template-columns: 1fr; } }
  </style>
</BaseLayout>
