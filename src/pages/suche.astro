---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const tools = await getCollection('tools');
const hubs = await getCollection('hubs');
const articles = await getCollection('articles');

type IndexEntry = { title: string; url: string; type: string; desc: string };

const sectionLabels: Record<string, string> = {
  'seo-wissen': 'SEO-Wissen',
  watchblog: 'Watchblog',
  ratgeber: 'Ratgeber',
};

const index: IndexEntry[] = [
  ...tools.map((t) => ({
    title: t.data.name,
    url: `/tools/review/${t.id}/`,
    type: 'Testbericht',
    desc: t.data.verdict,
  })),
  ...hubs.map((h) => ({
    title: h.data.title,
    url: `/tools/${h.id}/`,
    type: 'Vergleich',
    desc: h.data.intro,
  })),
  ...articles
    .filter((a) => !a.data.draft)
    .map((a) => ({
      title: a.data.title,
      url: `/artikel/${a.id}/`,
      type: sectionLabels[a.data.section] ?? 'Artikel',
      desc: a.data.excerpt,
    })),
];
---

<BaseLayout
  title="Suche - SEO Watchblog"
  description="Durchsuche Testberichte, Vergleiche und Artikel von SEO Watchblog."
>
  <div class="wrap">
    <div class="crumb"><a href="/">Home</a> › <span>Suche</span></div>
  </div>

  <section class="wrap page-head">
    <span class="eyebrow">Suche</span>
    <h1>Was suchst du?</h1>
    <p class="intro">Durchsuche alle Testberichte, Vergleiche und Ratgeber. Die Suche läuft direkt im Browser, ohne Verzögerung.</p>
  </section>

  <section class="wrap">
    <div class="search-box">
      <input
        type="search"
        id="q"
        autocomplete="off"
        autofocus
        placeholder="Tool, Thema oder Stichwort eingeben ..."
      />
    </div>
    <p class="result-meta" id="meta"></p>
    <div class="alt-grid" id="results"></div>
    <p class="empty" id="empty" hidden>Keine Treffer. Versuche ein anderes Stichwort.</p>
  </section>

  <script type="application/json" id="search-index" set:html={JSON.stringify(index)}></script>

  <script is:inline>
    (function () {
      const data = JSON.parse(document.getElementById('search-index').textContent || '[]');
      const input = document.getElementById('q');
      const results = document.getElementById('results');
      const meta = document.getElementById('meta');
      const empty = document.getElementById('empty');

      function esc(s) {
        return String(s).replace(/[&<>"']/g, (c) => ({
          '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
        }[c]));
      }

      function render(matches, q) {
        results.innerHTML = '';
        if (!q) {
          meta.textContent = '';
          empty.hidden = true;
          return;
        }
        if (matches.length === 0) {
          meta.textContent = '';
          empty.hidden = false;
          return;
        }
        empty.hidden = true;
        meta.textContent = matches.length + ' Treffer für „' + q + '“';
        for (const m of matches) {
          const a = document.createElement('a');
          a.className = 'alt-card';
          a.href = m.url;
          a.innerHTML =
            '<div class="s">' + esc(m.type) + '</div>' +
            '<h4>' + esc(m.title) + '</h4>' +
            '<p>' + esc(m.desc || '') + '</p>';
          results.appendChild(a);
        }
      }

      function search(q) {
        const term = q.trim().toLowerCase();
        if (!term) return [];
        return data.filter((e) =>
          (e.title + ' ' + e.desc + ' ' + e.type).toLowerCase().includes(term)
        );
      }

      function update() {
        const q = input.value;
        render(search(q), q.trim());
        const url = new URL(window.location);
        if (q.trim()) url.searchParams.set('q', q.trim());
        else url.searchParams.delete('q');
        history.replaceState(null, '', url);
      }

      input.addEventListener('input', update);

      const params = new URLSearchParams(window.location.search);
      const initial = params.get('q');
      if (initial) {
        input.value = initial;
        update();
      }
    })();
  </script>

  <style>
    .crumb { font-size: 13px; color: var(--color-stone-gray); padding: 26px 0 0; }
    .crumb a:hover { color: var(--color-action-azure); }
    .page-head { padding: 18px 0 32px; }
    .page-head .eyebrow { display: inline-block; background: rgba(237,237,237,0.85); font-size: 13px; font-weight: 500; padding: 5px 13px; border-radius: 24px; margin-bottom: 16px; }
    .page-head h1 { font-size: clamp(34px, 5vw, 52px); line-height: 1.05; letter-spacing: -1.4px; max-width: 820px; margin-bottom: 16px; }
    .page-head p.intro { font-size: 18px; color: #4a423d; max-width: 680px; line-height: 1.55; }

    section { padding: 40px 0; }

    .search-box { margin-bottom: 22px; }
    .search-box input {
      width: 100%; max-width: 720px; font-family: var(--font-sans); font-size: 18px;
      color: var(--color-inkwell); background: var(--color-snow);
      border: 1px solid var(--color-distant-sky); border-radius: var(--radius-cards);
      padding: 16px 22px; box-shadow: var(--shadow-subtle);
      transition: border-color .15s, box-shadow .15s;
    }
    .search-box input:focus {
      outline: none; border-color: var(--color-action-azure);
      box-shadow: 0 0 0 3px rgba(74,131,245,0.15);
    }
    .search-box input::placeholder { color: var(--color-stone-gray); }

    .result-meta { font-size: 14px; color: var(--color-stone-gray); margin-bottom: 18px; min-height: 18px; }
    .empty { font-size: 16px; color: var(--color-stone-gray); }

    .alt-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
    .alt-card { background: var(--color-snow); border-radius: var(--radius-cards); padding: 20px; box-shadow: var(--shadow-subtle); transition: transform .15s, box-shadow .15s; }
    .alt-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }
    .alt-card h4 { font-family: var(--font-serif); font-size: 18px; margin: 8px 0 6px; }
    .alt-card .s { font-size: 13px; color: var(--color-action-azure); font-weight: 600; }
    .alt-card p { font-size: 14px; color: #5a524d; line-height: 1.55; }

    @media (max-width: 1000px) {
      .alt-grid { grid-template-columns: 1fr; }
    }
  </style>
</BaseLayout>
